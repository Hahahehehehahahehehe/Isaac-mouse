                color3f inputs:diffuseColor.connect = </Mouse/_materials/Material_0_001/图像纹理.outputs:rgb>
                float inputs:ior = 1.5
                float inputs:metallic.connect = </Mouse/_materials/Material_0_001/图像纹理_001.outputs:b>
                float inputs:opacity = 1
                float inputs:roughness.connect = </Mouse/_materials/Material_0_001/图像纹理_001.outputs:g>
                float inputs:specular = 0.5
                token outputs:surface
            }

            def Shader "图像纹理"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/Image_0.001.png@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </Mouse/_materials/Material_0_001/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "uvmap"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }

            def Shader "图像纹理_001"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/Image_1.001.png@
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </Mouse/_materials/Material_0_001/uvmap.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:b
                float outputs:g
            }
        }
    }
}

